{
    "name": "ahmed-ebraheim72/html-fields",
    "description": "a package to help you to make form fields easier to use",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Ahmed Ebraheim",
            "email": "ahmedebraheim72@gmail.com"
        }
    ],
    "require": {
        "prabowosd/laravel-collective-html": "^13.0",
        "nesbot/carbon": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "HtmlFields\\": "src/"
        },
        "files": [
            "src/fieldLoader.php",
            "src/filesAttachment.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "HtmlFields\\HtmlFieldsServiceProvider"
            ]
        }
    }
}